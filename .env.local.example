# ============================================================
# Giấy Tờ AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# This example file IS committed — it contains no real values.
# ============================================================


# ============================================================
# ANTHROPIC
# ============================================================
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...


# ============================================================
# HELICONE (LLM cost tracking proxy)
# ============================================================
# Get from: helicone.ai → Settings → API Keys
# Optional but strongly recommended — tracks Claude API costs
HELICONE_API_KEY=sk-helicone-...


# ============================================================
# CLERK (Authentication)
# ============================================================
# Get from: dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs — do not change these values
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding


# ============================================================
# SUPABASE (Database)
# ============================================================
# Get from: supabase.com → your project → Settings → API
# For local dev: run `supabase start` and use the printed values
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# WARNING: Service role key bypasses RLS — server-side only


# ============================================================
# STRIPE (International payments — USD)
# ============================================================
# Get from: dashboard.stripe.com → Developers → API Keys
# Use test keys (sk_test_) for development
# Use live keys (sk_live_) for production ONLY
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — get from Stripe Dashboard → Products
# Create 4 products in Stripe before filling these in
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_UNLIMITED=price_...


# ============================================================
# PAYOS (Vietnamese local payments — VND)
# ============================================================
# Get from: business.payos.vn after merchant approval
# Use sandbox credentials for development
PAYOS_CLIENT_ID=...
PAYOS_API_KEY=...
PAYOS_CHECKSUM_KEY=...


# ============================================================
# CLOUDFLARE R2 (File storage)
# ============================================================
# Get from: dash.cloudflare.com → R2 → Manage R2 API tokens
CF_ACCOUNT_ID=...
CF_R2_ACCESS_KEY_ID=...
CF_R2_SECRET_ACCESS_KEY=...
CF_R2_BUCKET_NAME=giaytoai-uploads


# ============================================================
# UPSTASH REDIS (Rate limiting)
# ============================================================
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...


# ============================================================
# RESEND (Email)
# ============================================================
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@giaytoai.com


# ============================================================
# TRIGGER.DEV (Background jobs)
# ============================================================
# Get from: cloud.trigger.dev → your project → API Keys
TRIGGER_SECRET_KEY=tr_dev_...
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_...


# ============================================================
# SENTRY (Error tracking)
# ============================================================
# Get from: sentry.io → your project → Settings → SDK Setup
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0


# ============================================================
# POSTHOG (Product analytics)
# ============================================================
# Get from: app.posthog.com → your project → Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com


# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to https://giaytoai.com for production